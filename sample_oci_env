# OCI Configuration
OCI_CONFIG=./oci_config
OCT_FREE_AD=AD-1
DISPLAY_NAME='athena-otf'
# The other free shape is AMD: VM.Standard.E2.1.Micro
OCI_COMPUTE_SHAPE='VM.Standard.A1.Flex'
# ARM-specific configuration (ignored for E2.1.Micro)
OCI_ARM_OCPUS=4
OCI_ARM_MEMORY_GB=24
SECOND_MICRO_INSTANCE=False
REQUEST_WAIT_TIME_SECS=60
OCI_CRON_INTERVAL="*/30 * * * *"
SSH_AUTHORIZED_KEYS_FILE=./id_rsa.pub
# SUBNET_ID to use ONLY in case running in local or a non E2.1.Micro instance 
OCI_SUBNET_ID=
OCI_IMAGE_ID=
# The following will be ignored if OCI_IMAGE_ID is specified
OPERATING_SYSTEM="Canonical Ubuntu"
OS_VERSION=22.04
ASSIGN_PUBLIC_IP=false
# Boot volume size in GB (minimum is 50)
BOOT_VOLUME_SIZE=50

# Gmail Notification
NOTIFY_EMAIL=False
EMAIL=''
EMAIL_PASSWORD=''
